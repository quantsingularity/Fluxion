# Fluxion Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Vault ────────────────────────────────────────────────────────────────────
VAULT_ROOT_TOKEN=change-me-in-production
VAULT_LOG_LEVEL=info

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-strong-redis-password

# ─── Blockchain ───────────────────────────────────────────────────────────────
GANACHE_MNEMONIC=candy maple cake sugar pudding cream honey rich smooth crumble sweet treat
GANACHE_NETWORK_ID=1337
GANACHE_CHAIN_ID=1337
GANACHE_ACCOUNTS=10
GANACHE_DEFAULT_BALANCE=100

# ─── Application ──────────────────────────────────────────────────────────────
LOG_LEVEL=info
API_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:3000

# ─── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change-me-grafana-admin-password
GRAFANA_SECRET_KEY=change-me-32-char-grafana-secret-key
PROMETHEUS_RETENTION=30d

# ─── Logging ──────────────────────────────────────────────────────────────────
ELASTIC_PASSWORD=change-me-elastic-password
KIBANA_ENCRYPTION_KEY=change-me-32-char-kibana-encryption-key
