# ============================================================
# Fluxion API – Environment Configuration
# Copy to .env and adjust values before running
# ============================================================

# ----- Application -----
APP_NAME=Fluxion API
VERSION=2.0.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_HOSTS=*

# ----- Database (PostgreSQL) -----
DATABASE_URL=postgresql+asyncpg://fluxion:fluxion@db:5432/fluxion
# DATABASE_READ_URL=postgresql+asyncpg://fluxion:fluxion@db-replica:5432/fluxion
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false

# ----- Redis -----
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20
CACHE_TTL=3600
SESSION_TTL=86400

# ----- Security -----
# IMPORTANT: Generate a strong secret key for production!
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=development-secret-key-change-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=8
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100

# Optional: Field-level encryption key (Fernet key, base64-url encoded)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=
FIELD_ENCRYPTION_ENABLED=false

# ----- Blockchain -----
ETH_RPC_URL=http://localhost:8545
# ETH_WEBSOCKET_URL=
ETH_CHAIN_ID=1
# POLYGON_RPC_URL=
# BSC_RPC_URL=
GAS_PRICE_STRATEGY=medium
MAX_GAS_PRICE=100

# Contract addresses (set after deployment)
# SUPPLY_CHAIN_ADDRESS=
# LIQUIDITY_POOL_ADDRESS=
# SYNTHETIC_ASSET_ADDRESS=
# GOVERNANCE_TOKEN_ADDRESS=

# API Keys
# ETHERSCAN_API_KEY=
# POLYGONSCAN_API_KEY=

# ----- Compliance -----
KYC_ENABLED=false
# KYC_PROVIDER=jumio
# KYC_API_KEY=
# KYC_API_SECRET=
AML_ENABLED=false
# AML_PROVIDER=chainalysis
# AML_API_KEY=
TRANSACTION_MONITORING_ENABLED=false
SUSPICIOUS_AMOUNT_THRESHOLD=10000.0
DAILY_TRANSACTION_LIMIT=50000.0
REGULATORY_REPORTING_ENABLED=false
AUDIT_LOG_RETENTION_DAYS=2555

# ----- Monitoring -----
METRICS_ENABLED=true
METRICS_PORT=8001
HEALTH_CHECK_INTERVAL=30
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development

# ----- External Services -----
# NOTIFICATION_SERVICE_URL=
# ANALYTICS_SERVICE_URL=
